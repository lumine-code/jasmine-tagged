{
  "name": "@lumine-code/jasmine-tagged",
  "version": "2.0.0",
  "description": "Filters legacy Jasmine specs by inherited tags for Lumine test suites.",
  "main": "./lib/jasmine-tagged.js",
  "license": "MIT",
  "repository": "https://github.com/lumine-code/jasmine-tagged",
  "bugs": "https://github.com/lumine-code/jasmine-tagged/issues",
  "homepage": "https://github.com/lumine-code/jasmine-tagged/",
  "author": "lumine-code",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "lib"
  ],
  "scripts": {
    "build": "coffee --compile --output lib src",
    "pretest": "npm run build",
    "test": "node node_modules/jasmine-focused/bin/jasmine-focused --captureExceptions --coffee spec/",
    "prepare": "npm run build"
  },
  "bin": {
    "jasmine-tagged": "./bin/jasmine-tagged"
  },
  "devDependencies": {
    "coffeescript": "2.7.0"
  },
  "dependencies": {
    "jasmine-focused": "https://github.com/lumine-code/jasmine-focused.git#5bb81cbfeafbd91f04b0981ca600cf94899d66b6"
  }
}
